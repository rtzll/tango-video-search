{
	"name": "tango-video-search",
	"private": true,
	"license": "BSD-3-Clause",
	"repository": {
		"type": "git",
		"url": "https://github.com/rtzll/tango-video-search.git"
	},
	"type": "module",
	"engines": {
		"node": ">=24.11.0"
	},
	"knip": {
		"ignoreDependencies": [
			"cloudflare"
		]
	},
	"sideEffects": false,
	"scripts": {
		"build": "react-router build",
		"db:update": "node scripts/update-cloudflare-db.ts",
		"deploy": "react-router build && wrangler deploy",
		"dev": "react-router dev",
		"preview": "react-router build && wrangler dev --local --config build/server/wrangler.json --persist-to .wrangler/state",
		"lint": "oxlint .",
		"lint:fix": "oxlint --fix .",
		"format": "oxfmt --write .",
		"check": "oxlint . && vitest run && react-router typegen && tsc && knip && react-router build",
		"typecheck": "react-router typegen && tsc",
		"knip": "knip",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@radix-ui/react-icons": "^1.3.2",
		"@tailwindcss/vite": "^4.3.3",
		"drizzle-orm": "^0.40.1",
		"isbot": "^5.2.1",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-router": "^8.2.0"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.45.1",
		"@cloudflare/vitest-pool-workers": "^0.18.6",
		"@cloudflare/workers-types": "^5.20260718.1",
		"@react-router/dev": "^8.2.0",
		"@types/node": "^24.13.3",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"knip": "^5.88.1",
		"oxfmt": "^0.46.0",
		"oxlint": "^1.74.0",
		"tailwindcss": "^4.3.3",
		"typescript": "^6.0.3",
		"vite": "^7.3.6",
		"vite-plus": "^0.2.5",
		"vitest": "4.1.10",
		"wrangler": "^4.112.0"
	},
	"packageManager": "pnpm@10.33.2"
}
