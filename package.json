{
	"name": "tango-video-search",
	"private": true,
	"license": "BSD-3-Clause",
	"repository": {
		"type": "git",
		"url": "https://github.com/rtzll/tango-video-search.git"
	},
	"type": "module",
	"sideEffects": false,
	"scripts": {
		"build": "bunx --bun --no-install react-router build",
		"dev": "bunx --bun --no-install react-router dev",
		"db:update": "bun scripts/update-production-db.ts",
		"lint": "oxlint .",
		"lint:fix": "oxlint --fix .",
		"format": "oxfmt --write .",
		"check": "bun run lint && bun run typecheck && bun run knip && bun run build",
		"start": "bunx --bun --no-install react-router-serve ./build/server/index.js",
		"typecheck": "bunx --bun --no-install react-router typegen && tsc",
		"knip": "knip"
	},
	"dependencies": {
		"@radix-ui/react-icons": "^1.3.2",
		"@react-router/node": "^7.18.0",
		"@react-router/serve": "^7.18.0",
		"@tailwindcss/vite": "^4.3.1",
		"drizzle-orm": "^0.40.1",
		"isbot": "^5.1.44",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-router": "^7.18.0"
	},
	"devDependencies": {
		"@react-router/dev": "^7.18.0",
		"@types/bun": "^1.3.14",
		"@types/node": "^24.13.2",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"knip": "^5.88.1",
		"oxfmt": "^0.46.0",
		"oxlint": "^1.71.0",
		"tailwindcss": "^4.3.1",
		"typescript": "^5.9.3",
		"vite": "^6.4.3",
		"vite-tsconfig-paths": "^5.1.4"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"packageManager": "bun@1.3.14"
}
