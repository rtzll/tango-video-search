{
	"name": "tango-video-search",
	"private": true,
	"license": "BSD-3-Clause",
	"repository": {
		"type": "git",
		"url": "https://github.com/rtzll/tango-video-search.git"
	},
	"type": "module",
	"sideEffects": false,
	"scripts": {
		"build": "react-router build",
		"db:update": "node scripts/update-cloudflare-db.mjs",
		"deploy": "react-router build && wrangler deploy",
		"dev": "react-router dev",
		"preview": "react-router build && wrangler dev --local --config build/server/wrangler.json --persist-to .wrangler/state",
		"lint": "oxlint .",
		"lint:fix": "oxlint --fix .",
		"format": "oxfmt --write .",
		"check": "oxlint . && react-router typegen && tsc && knip && react-router build",
		"typecheck": "react-router typegen && tsc",
		"knip": "knip"
	},
	"dependencies": {
		"@radix-ui/react-icons": "^1.3.2",
		"@tailwindcss/vite": "^4.3.2",
		"drizzle-orm": "^0.40.1",
		"isbot": "^5.1.44",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-router": "^8.1.0"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.42.4",
		"@cloudflare/workers-types": "^4.20260701.1",
		"@react-router/dev": "^8.1.0",
		"@types/node": "^24.13.2",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"knip": "^5.88.1",
		"oxfmt": "^0.46.0",
		"oxlint": "^1.72.0",
		"tailwindcss": "^4.3.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.6",
		"vite-plus": "^0.2.1",
		"vite-tsconfig-paths": "^5.1.4",
		"wrangler": "^4.106.0"
	},
	"packageManager": "pnpm@10.33.2"
}
